### NestJS server
NODE_ENV=production
PORT=3001

### Frontend origin (CORS allowlist). Comma-separated for multi-env.
# Local dev: http://localhost:3000
# Prod    : https://app.example.com
FRONTEND_ORIGIN=https://app.example.com

### Cookie name carried over from Phase1 for continuity.
SESSION_COOKIE_NAME=gyomu_session
# When the API and the SPA share a parent domain we can use SameSite=Lax.
# If they're on different registrable domains, set: COOKIE_SAME_SITE=none
# and ensure HTTPS — Set-Cookie SameSite=None requires Secure.
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=.example.com

### JWT
# Use a 256-bit+ random string. Rotate on suspected compromise.
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=12h

### Database (AWS RDS)
# Username/password authentication. For IAM auth, swap in a token generator.
DATABASE_HOST=gyomu-prod.xxxxxxxx.ap-northeast-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=gyomu_navi
DATABASE_USERNAME=gyomu_app
DATABASE_PASSWORD=replace-me
DATABASE_SSL=true

### S3 (image uploads). Bucket should be private; objects served via presigned URL.
S3_REGION=ap-northeast-1
S3_BUCKET=gyomu-navi-reports-prod
# Object key prefix. Restrict the issuing IAM role to this prefix.
S3_KEY_PREFIX=reports/
# Presigned PUT URLs are valid this many seconds.
S3_PRESIGN_TTL_SECONDS=300

### Logging
LOG_LEVEL=info
