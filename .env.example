# Next.js and API routes (copy to .env)
DATABASE_URL=postgresql://gyomu:gyomu@localhost:5432/gyomu_navi
# Neon: paste the full URL from the Neon console (Connect → Node.js or psql).
# Optional ?sslmode=require in the URL is fine; the app also enables SSL when the host is neon.tech.
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# If SSL is not auto-detected, set: DATABASE_SSL=true
JWT_SECRET=change-this-to-a-long-random-string-in-production
# 複数のフロントURLはカンマ区切り（CORS; 分離 API のとき用｜Monolithic Next では同オリジンで不要なことが多い）
# FRONTEND_ORIGIN=http://localhost:3000

# フロントと API を別デプロイにする本番: Cookie をクロスサイトで送る（HTTPS 必須）
# COOKIE_SAME_SITE=none

# Set to true to allow POST /api/auth/register (e.g. first user); keep false in production
# ALLOW_REGISTER=false

# フロントを別ホスト、API だけをこの Next 以外のサーバーに向ける場合（末尾スラッシュなし）
# NEXT_PUBLIC_API_BASE_URL=https://your-api.railway.app
